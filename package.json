{
  "name": "live-proxy-server",
  "version": "1.0.0",
  "description": "",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "start:server": "node server/index.mjs",
    "dev": "node server/index.mjs",
    "dev:ui": "vite",
    "dev:all": "concurrently -k \"node server/index.mjs\" \"vite\"",
    "build:web": "vite build",
    "build": "npm run build:web && electron-builder --win nsis",
    "preview": "vite preview",
    "pack": "npm run build:web && electron-builder --dir",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "express": "^5.2.1",
    "undici": "^6.19.8",
    "vue": "^3.5.30",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "vite": "^8.0.1"
  },
  "build": {
    "appId": "com.liveproxy.server",
    "productName": "LiveProxyServer",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "server/**",
      "dist/**",
      "config.json",
      "server/config.json",
      "node_modules/**"
    ],
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "config.json",
      "server/config.json",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
